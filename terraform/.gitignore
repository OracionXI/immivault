# Local Terraform state (never commit)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Variable files with secrets (add back specific non-secret tfvars if needed)
*.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
